//
// Reference: identical kernel WITHOUT "cutlass" in function name
//

.version 8.7
.target sm_100a
.address_size 64

.visible .entry plain_kernel(
	.param .u32 param_n
)
.reqntid 128
.maxnreg 128
{
	.reg .pred	%p<3>;
	.reg .b32	%r<6>;
	.reg .b64	%rd<3>;

	mov.u32	%r1, %tid.x;
	setp.lt.u32	%p0, %r1, 32;

	ld.param.u32	%r2, [param_n];
	mov.b64	%rd0, 0;
	mov.b64	%rd1, 0;
	mov.b32	%r3, 0;
	mov.pred	%p1, 0;
	mov.u32	%r4, 0;
	mov.b32	%r5, 0;

$L__loop:
	@%p0 tcgen05.mma.cta_group::1.kind::f8f6f4 [%r5 + 0], %rd0, %rd1, %r3, %p1;
	add.s32	%r4, %r4, 1;
	setp.lt.u32	%p2, %r4, %r2;
	@%p2 bra	$L__loop;

	ret;
}
